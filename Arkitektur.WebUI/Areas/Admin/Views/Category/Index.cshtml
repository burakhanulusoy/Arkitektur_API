@model List<ResultCategoryDto>


@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<h1>Kategoriler</h1>

<table class="table table-bordered table-hover">

    <tr>
        <td>#</td>
        <td>Kategori Adı</td>
        <td>Oluşturulma Tarihi</td>
        <td>İşlemler</td>
    </tr>

    @foreach(var item in Model)
    {
        count++;
        <tr>
            <td>@count</td>
            <td>@item.CategoryName</td>
            <td>@item.CreatedAt.ToString("dd MMMM dddd")</td>
            <td>

                <a href="/Admin/Category/UpdateCategory/@item.Id" class="btn btn-primary">Düzenle</a>
                <a href="/Admin/Category/DeleteCategory/@item.Id" class="btn btn-danger">Sil</a>

            </td>
        </tr>
    }





</table>

<a href="/Admin/Category/CreateCategory" class="btn btn-success">Yeni Kategori Ekle</a>



<script>

    function deleteCategory(id){
            Swal.fire({
      title: "Silmek istediğinize emin misiniz ?",
      text: "Bu işlemi geri alamazsınız!",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      cancelButtonColor: "#d33",
      confirmButtonText: "Evet, sil!",
      cancelButtonText:"İptal"
    }).then((result) => {
      if (result.isConfirmed){

          window.location.href="/Admin/Category/DeleteCategory/"+id;
           Swal.fire({
        title: "Silindi!",
        text: "Öğeniz başarılı bir şekilde silindi.",
        icon: "success"
      });


      } 
     
    });
    }

</script>






