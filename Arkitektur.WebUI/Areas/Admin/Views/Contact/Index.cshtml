@model List<ResultContactDto>

@{
    ViewData["Title"] = "İletişim Bilgileri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="m-0 font-weight-bold text-primary">
                <i class="bi bi-envelope-open me-2"></i> İletişim Bilgileri Listesi
            </h5>
            <a class="btn btn-success btn-sm shadow-sm" href="/Admin/Contact/CreateContact">
                <i class="bi bi-plus-circle me-1"></i> Yeni İletişim Bilgisi Ekle
            </a>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px">#</th>
                            <th>İletişim Kanalları</th>
                            <th>Adres</th>
                            <th style="width: 300px">Harita Konumu</th>
                            <th class="text-center" style="width: 200px">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td class="fw-bold text-muted">@count</td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span><i class="bi bi-telephone text-primary me-2"></i>@item.PhoneNumber</span>
                                        <small class="text-muted"><i class="bi bi-envelope-at text-danger me-2"></i>@item.Email</small>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-wrap" style="max-width: 200px; display: block;">
                                        @item.Address
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.MapUrl))
                                    {
                                        <div class="map-container shadow-sm">
                                            @Html.Raw(item.MapUrl)
                                            <div class="map-overlay">
                                                <i class="bi bi-geo-alt-fill text-danger"></i> Kayıtlı Konum
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="bg-light border rounded p-3 text-center text-muted small">
                                            <i class="bi bi-map me-1"></i> Harita Eklenmemiş
                                        </div>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm" role="group">
                                        <a href="/Admin/Contact/UpdateContact/@item.Id" class="btn btn-outline-primary btn-sm" title="Düzenle">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <button onclick="deleteContact(@item.Id)" class="btn btn-outline-danger btn-sm" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Harita Konteyneri Tasarımı */
    .map-container {
        width: 100%;
        height: 120px;
        position: relative;
        border-radius: 10px;
        overflow: hidden;
        border: 2px solid #f8f9fa;
        transition: all 0.3s ease;
    }

        .map-container:hover {
            transform: scale(1.02);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important;
        }

        .map-container iframe {
            width: 100% !important;
            height: 100% !important;
            filter: grayscale(20%);
        }

    .map-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(255,255,255,0.85);
        padding: 4px 8px;
        font-size: 11px;
        font-weight: bold;
        text-align: center;
        backdrop-filter: blur(2px);
    }

    /* Tablo Düzenlemeleri */
    .table thead th {
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6c757d;
        border-top: none;
    }

    .btn-group .btn {
        padding: 0.4rem 0.8rem;
    }

    /* Badge ve Text */
    .text-wrap {
        line-height: 1.4;
        font-size: 0.9rem;
    }
</style>

<script>
    function deleteContact(id) {
        Swal.fire({
            title: "Emin misiniz?",
            text: "Bu iletişim bilgisini silmek istediğinizden emin misiniz?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33",
            cancelButtonColor: "#6c757d",
            confirmButtonText: "Evet, Sil!",
            cancelButtonText: "İptal",
            background: '#fff',
            borderRadius: '15px'
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.fire({
                    title: "Silindi!",
                    text: "Kayıt başarıyla kaldırıldı.",
                    icon: "success",
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    window.location.href = "/Admin/Contact/DeleteContact/" + id;
                });
            }
        });
    }
</script>