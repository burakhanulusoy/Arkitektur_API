
@model CreateAboutDto

@{
    ViewData["Title"] = "CreateAbout";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<form enctype="multipart/form-data" method="post">
    
    <div class="form-group">
        <label>Kuruluş Yılı</label>
        <input type="number" placeholder="Kuruluş Yılını Yazınız..." asp-for="StartYear" class="form-control" />
        <span class="text-danger" asp-validation-for="StartYear"></span>
    </div>

    <div class="form-group">
        <label>Başlık</label>
        <input type="text" placeholder="Başlık Yazınız..." asp-for="Title" class="form-control" />
        <span class="text-danger" asp-validation-for="Title"></span>
    </div>


    <div class="form-group">
        <label>Açıklama</label>
        <textarea type="text" placeholder="Açıklama Yazınız..." asp-for="Description" class="form-control" cols="4"></textarea>
        <span class="text-danger" asp-validation-for="Description"></span>
    </div>

    <div class="form-group">
        <label>Görsel Seçin</label>
        <input type="file" placeholder="Görsel Seçiniz..." asp-for="file"  class="form-control" />
        <span class="text-danger" asp-validation-for="file"></span>
    </div>

    <button class="btn btn-success">Oluştur</button>






</form>

