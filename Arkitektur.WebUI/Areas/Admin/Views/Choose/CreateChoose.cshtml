@model CreateChooseDto

@{
    ViewData["Title"] = "CreateBanner";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}




<form   method="post">

    <div class="form-group">
        <label>Başlık</label>
        <input type="text" placeholder="Başlık Yazınız..." asp-for="Title" class="form-control"  />
        <span class="text-danger" asp-validation-for="Title"></span>
    </div>

    <div class="form-group">
        <label>Açıklama</label>
        <textarea placeholder="Açıklama Yazınız..." asp-for="Description" class="form-control" rows="4" ></textarea>
        <span class="text-danger" asp-validation-for="Description"></span>
    </div>

    <div class="form-group">
        <label>İcon Url Giriniz</label>
        <input type="url" placeholder="İcon Url Giriniz..." asp-for="Icon" class="form-control"  />
        <span class="text-danger" asp-validation-for="Icon"></span>
    </div>

    <button class="btn btn-success">Oluştur</button>

</form>
