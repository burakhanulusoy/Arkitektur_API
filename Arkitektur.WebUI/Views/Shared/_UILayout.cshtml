
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

    @await Component.InvokeAsync("_AdminHeadViewComponents")


<body>
 
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border position-relative text-primary" style="width: 6rem; height: 6rem;" role="status"></div>
        <img class="position-absolute top-50 start-50 translate-middle" src="~/arkitektur-1.0.0/img/icons/icon-1.png" alt="Icon">
    </div>
    
    @await Component.InvokeAsync("_AdminTopBarViewComponents")


    @await Component.InvokeAsync("_AdminNavbarViewComponents")
   
 
    @RenderBody()




    <!-- Footer Start -->
    @await Component.InvokeAsync("_AdminFooterViewComponents")
    <!-- Footer End -->
    <!-- Back to Top -->
    <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>


    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/arkitektur-1.0.0/lib/wow/wow.min.js"></script>
    <script src="~/arkitektur-1.0.0/lib/easing/easing.min.js"></script>
    <script src="~/arkitektur-1.0.0/lib/waypoints/waypoints.min.js"></script>
    <script src="~/arkitektur-1.0.0/lib/counterup/counterup.min.js"></script>
    <script src="~/arkitektur-1.0.0/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="~/arkitektur-1.0.0/lib/tempusdominus/js/moment.min.js"></script>
    <script src="~/arkitektur-1.0.0/lib/tempusdominus/js/moment-timezone.min.js"></script>
    <script src="~/arkitektur-1.0.0/lib/tempusdominus/js/tempusdominus-bootstrap-4.min.js"></script>

    <!-- Template Javascript -->
    <script src="~/arkitektur-1.0.0/js/main.js"></script>
</body>

</html>