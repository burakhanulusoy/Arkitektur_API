@model CreateTeamDto
@{
    ViewData["Title"] = "Yeni Takım Üyesi Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h5 class="mb-0">Yeni Takım Üyesi Ekle</h5>
    </div>
    <div class="card-body">
        <form enctype="multipart/form-data" method="post">

            <div class="mb-3">
                <label class="form-label fw-bold">Takım Üyesi Adı ve Soyadı</label>
                <input type="text" placeholder="Örn: Ahmet Yılmaz" asp-for="NameSurname" class="form-control" />
                <span class="text-danger" asp-validation-for="NameSurname"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mesleği / Ünvanı</label>
                <input type="text" placeholder="Örn: Mimari Tasarımcı" asp-for="Title" class="form-control" />
                <span class="text-danger" asp-validation-for="Title"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Profil Görseli Seçin</label>
                <input type="file" asp-for="file" class="form-control" accept="image/*" />
                <span class="text-danger" asp-validation-for="file"></span>
                <div class="form-text text-muted">Takım üyesinin yüzünün net göründüğü bir fotoğraf yükleyiniz.</div>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <a href="/Admin/Team/Index" class="btn btn-secondary me-2">
                    <i class="bi bi-x-circle me-1"></i> İptal
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-circle me-1"></i> Oluştur
                </button>
            </div>

        </form>
    </div>
</div>