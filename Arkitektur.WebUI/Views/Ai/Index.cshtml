@{
    ViewData["Title"] = "AI Haritalı İmar Analisti";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Arkitektur</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <style>
        body {
            font-family: 'Montserrat', sans-serif;
            background: linear-gradient(135deg, #1f1f1f 0%, #0a0a0a 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 3rem 0;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
            overflow: hidden;
        }

        .card-header-custom {
            background: #111;
            color: #fff;
            padding: 2rem;
            text-align: center;
            border-bottom: 4px solid #d4af37;
        }
        /* Harita Alanı Tasarımı */
        #map {
            height: 450px;
            width: 100%;
            border-radius: 10px;
            border: 2px solid #333;
            margin-bottom: 15px;
            cursor: crosshair;
        }

        .form-control {
            border-radius: 10px;
            background-color: #f8f9fa;
        }

            .form-control:focus {
                border-color: #d4af37;
                box-shadow: 0 0 0 0.25rem rgba(212, 175, 55, 0.25);
            }

        .btn-custom {
            background-color: #111;
            color: #d4af37;
            border-radius: 10px;
            transition: all 0.3s ease;
        }

            .btn-custom:hover {
                background-color: #d4af37;
                color: #111;
                transform: translateY(-2px);
            }

        .selected-info {
            background: #222;
            padding: 15px;
            border-radius: 8px;
            font-size: 0.95rem;
            color: #fff;
            display: none;
            border-left: 5px solid #d4af37;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-md-12">
                <div class="glass-card">
                    <div class="card-header-custom">
                        <h2 class="mb-1 fw-light">
                            Arkitektur <span class="fw-bold">AI Harita Analizi</span>
                        </h2>
                        <p class="text-light opacity-75 mb-0" style="letter-spacing: 2px; font-size: 0.9rem;">UYDU DESTEKLİ İNTERAKTİF LOKASYON HESAPLAMA</p>
                    </div>
                    <div class="card-body p-4 p-md-5">

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger border-0 shadow-sm rounded-3 fw-bold" role="alert">
                                ⚠️ @ViewBag.Error
                            </div>
                        }

                        <p class="text-muted mb-4 text-center" style="font-size: 1.05rem;">
                            Uydu haritası üzerinden analiz yapmak istediğiniz <strong>boş araziye</strong> tıklayın ve hayalinizdeki evi tarif edin.
                        </p>

                        <form asp-controller="Ai" asp-action="Analyze" method="post" id="aiForm">

                            <input type="hidden" id="City" name="City" />
                            <input type="hidden" id="FullAddress" name="FullAddress" />
                            <input type="hidden" id="Latitude" name="Latitude" />
                            <input type="hidden" id="Longitude" name="Longitude" />

                            <div class="mb-4">
                                <label class="form-label fw-bold text-dark">1. Arazi Seçimi (Uydu Haritasına Tıklayın)</label>

                                <div id="map"></div>

                                <div id="selectedInfo" class="selected-info mt-3 shadow-sm">
                                    <strong class="text-warning">📍 Konum Tespit Edildi:</strong> <br />
                                    <span id="cityNameDisplay" class="text-light">Bekleniyor...</span>
                                </div>
                            </div>

                            <div class="mb-5 mt-4">
                                <label for="HouseDescription" class="form-label fw-bold text-dark">2. Hayalinizdeki Yapı Özellikleri</label>
                                <textarea class="form-control" id="HouseDescription" name="HouseDescription" rows="4" placeholder="Örn: 2 katlı, Amerikan mutfaklı, taş dış cephe kaplamalı şık bir villa..." required></textarea>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-custom btn-lg py-3 fw-bold shadow" id="submitBtn">
                                    ARAZİYİ VE MALİYETİ ANALİZ ET
                                </button>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 1. Haritayı Başlat (Başlangıç noktası olarak zoom seviyesini 13 yaptık, daha yakından açılacak)
        var map = L.map('map').setView([39.4200, 29.9860], 13);

        // 2. PROFESYONEL GOOGLE HYBRID HARİTASI (Uydu + Sokak/İlçe İsimleri + Bina Sınırları)
        L.tileLayer('http://{s}.google.com/vt/lyrs=y&x={x}&y={y}&z={z}', {
            maxZoom: 20,
            subdomains:['mt0','mt1','mt2','mt3'],
            attribution: '&copy; Google Haritalar & Arkitektur'
        }).addTo(map);

        var marker;

        // 3. Haritaya Tıklama Olayı (Event)
        map.on('click', function(e) {
            var lat = e.latlng.lat;
            var lng = e.latlng.lng;

            if(marker) {
                map.removeLayer(marker);
            }
            marker = L.marker([lat, lng]).addTo(map);

            document.getElementById('Latitude').value = lat;
            document.getElementById('Longitude').value = lng;

            document.getElementById('selectedInfo').style.display = 'block';
            document.getElementById('cityNameDisplay').innerText = "Adres detayları çözümleniyor, lütfen bekleyin...";

            // 4. Koordinattan Tam Adres Bulma
            var url = `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=18&addressdetails=1`;

            fetch(url)
                .then(response => response.json())
                .then(data => {
                    var city = data.address.province || data.address.city || data.address.state || data.address.region || "Bilinmeyen Bölge";
                    var fullAddress = data.display_name || "Adres detayı bulunamadı";

                    document.getElementById('City').value = city;
                    document.getElementById('FullAddress').value = fullAddress;

                    document.getElementById('cityNameDisplay').innerText = fullAddress;
                })
                .catch(error => {
                    console.log("Adres çekilirken hata oluştu: ", error);
                    document.getElementById('cityNameDisplay').innerText = "Konum işaretlendi (Adres sunucusundan yanıt alınamadı)";
                    document.getElementById('City').value = "Bilinmeyen Bölge";
                    document.getElementById('FullAddress').value = "Koordinat seçildi, tam adres çözümlenemedi.";
                });
        });

        // 5. Form Doğrulama
        document.getElementById('aiForm').addEventListener('submit', function(e) {
            var lat = document.getElementById('Latitude').value;
            if (!lat || lat === "") {
                e.preventDefault();
                alert("Lütfen önce uydu haritası üzerinden analiz yapmak istediğiniz araziye tıklayın!");
            }
        });
    </script>

</body>
</html>