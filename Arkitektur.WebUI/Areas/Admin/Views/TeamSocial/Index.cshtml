@model List<GetTeamSocialWithTeamMemberDto>

@{
    ViewData["Title"] = "Sosyal Medya Hesapları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">Takım Sosyal Medya Hesapları</h5>
        <a class="btn btn-success" href="/Admin/TeamSocial/CreateTeamSocial">
            <i class="bi bi-plus-circle me-1"></i> Yeni Hesap Ekle
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" style="width: 5%;" class="py-3 fs-6">#</th>
                        <th scope="col" style="width: 10%;" class="py-3 fs-6 text-center">İkon</th>
                        <th scope="col" style="width: 20%;" class="py-3 fs-6">Platform</th>
                        <th scope="col" style="width: 25%;" class="py-3 fs-6">Hesap Sahibi</th>
                        <th scope="col" style="width: 15%;" class="py-3 fs-6 text-center">Bağlantı</th>
                        <th scope="col" style="width: 25%;" class="text-center py-3 fs-6">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td class="py-3"><strong>@count</strong></td>
                            <td class="py-3 text-center">
                                <img src="@item.Icon" alt="@item.Title İkonu" class="img-thumbnail shadow-sm" style="width: 50px; height: 50px; object-fit: contain; background-color: #f8f9fa;" />
                            </td>
                            <td class="py-3 fs-6 fw-semibold">@item.Title</td>
                            <td class="py-3">
                                <span class="badge bg-secondary fs-6 px-3 py-2">@item.Team.NameSurname</span>
                            </td>
                            <td class="py-3 text-center">
                                <a target="_blank" class="btn btn-outline-dark btn-sm px-3" href="@item.Url">
                                    <i class="bi bi-box-arrow-up-right me-1"></i> Git
                                </a>
                            </td>
                            <td class="text-center py-3">
                                <a href="/Admin/TeamSocial/UpdateTeamSocial/@item.Id" class="btn btn-primary px-3">
                                    <i class="bi bi-pencil-square"></i> Düzenle
                                </a>
                                <button onclick="deleteTeamSocial(@item.Id)" class="btn btn-danger px-3">
                                    <i class="bi bi-trash"></i> Sil
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function deleteTeamSocial(id) {
        Swal.fire({
            title: "Silmek istediğinize emin misiniz?",
            text: "Bu işlemi geri alamazsınız!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Evet, sil!",
            cancelButtonText: "İptal"
        }).then((result) => {
            if (result.isConfirmed) {

                // Başarı mesajını ayarla ve bitmesini bekle
                Swal.fire({
                    title: "Silindi!",
                    text: "Öğeniz başarılı bir şekilde silindi.",
                    icon: "success",
                    showConfirmButton: false, // Onay butonunu gizle
                    timer: 2000, // Ekranda 2 saniye (2000ms) kalsın
                    timerProgressBar: true // Şık bir geri sayım barı ekle
                }).then(() => {
                    // Alert süresi dolup kapandıktan SONRA yönlendirmeyi yap
                    window.location.href = "/Admin/TeamSocial/DeleteTeamSocial/" + id;
                });

            }
        });
    }
</script>