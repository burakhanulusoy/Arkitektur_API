@model List<ResultAppointmentDto>

@*
    navbar admin
*@

<div class="main-panel">
    <div class="main-header">
        <div class="main-header-logo">
            <div class="logo-header" data-background-color="dark">
                <a href="index.html" class="logo">
                    <img src="~/kaiadmin-lite-1.2.0/assets/img/kaiadmin/logo_light.svg"
                         alt="navbar brand"
                         class="navbar-brand"
                         height="20" />
                </a>
                <div class="nav-toggle">
                    <button class="btn btn-toggle toggle-sidebar">
                        <i class="gg-menu-right"></i>
                    </button>
                    <button class="btn btn-toggle sidenav-toggler">
                        <i class="gg-menu-left"></i>
                    </button>
                </div>
                <button class="topbar-toggler more">
                    <i class="gg-more-vertical-alt"></i>
                </button>
            </div>
        </div>

        <nav class="navbar navbar-header navbar-header-transparent navbar-expand-lg border-bottom">
            <div class="container-fluid">
                <nav class="navbar navbar-header-left navbar-expand-lg navbar-form nav-search p-0 d-none d-lg-flex">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <button type="submit" class="btn btn-search pe-1">
                                <i class="fa fa-search search-icon"></i>
                            </button>
                        </div>
                        <input type="text"
                               placeholder="Search ..."
                               class="form-control" />
                    </div>
                </nav>

                <ul class="navbar-nav topbar-nav ms-md-auto align-items-center">

                    <li class="nav-item topbar-icon dropdown hidden-caret">
                        <a class="nav-link dropdown-toggle"
                           href="#"
                           id="messageDropdown"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-haspopup="true"
                           aria-expanded="false">
                            <i class="bi bi-envelope fs-4"></i>
                            <span class="notification">@ViewBag.Count</span>
                        </a>
                        <ul class="dropdown-menu messages-notif-box animated fadeIn"
                            aria-labelledby="messageDropdown">
                            <li>
                                <div class="dropdown-title d-flex justify-content-between align-items-center">
                                    Bekleyen Randevular
                                    <a href="/Admin/Appointment/Index" class="small">Hepsini Gör</a>
                                </div>
                            </li>
                            <li>
                                <div class="message-notif-scroll scrollbar-outer">
                                    <div class="notif-center">
                                      
                                        @foreach(var item in Model)
                                        {
                                            <a href="#">
                                                <div class="notif-img">
                                                    <img src="data:image/png;base64,"
                                                         alt="Img Profile" />
                                                </div>
                                                <div class="notif-content">
                                                    <span class="subject">@item.NameSurname</span>

                                                    <span class="block">
                                                        @(item.Message.Length > 30 ? item.Message.Substring(0, 30) + "..." : item.Message)
                                                    </span>
                                                    @{
                                                        var fark = DateTime.Now - item.AppointmentDate;
                                                    }
                                                    <span class="time">@fark.Days gün, @fark.Hours saat, @fark.Minutes dk önce</span>
                                                </div>
                                            </a>
                                        }

                                    </div>
                                </div>
                            </li>
                            <li>
                               
                            </li>
                        </ul>
                    </li>






                    <li class="nav-item topbar-user dropdown hidden-caret">
                        <a class="dropdown-toggle profile-pic"
                           data-bs-toggle="dropdown"
                           href="#"
                           aria-expanded="false">
                            <div class="avatar-sm">
                                <img src="@ViewBag.ImageUrl"
                                     alt="..."
                                     class="avatar-img rounded-circle" />
                            </div>
                            <span class="profile-username">
                                <span class="op-7">Hi,</span>
                                <span class="fw-bold">@ViewBag.FullName</span>
                            </span>
                        </a>
                        <ul class="dropdown-menu dropdown-user animated fadeIn">
                            <div class="dropdown-user-scroll scrollbar-outer">
                            <li>
                                <div class="user-box">
                                    <div class="avatar-lg">
                                        <img src="~/kaiadmin-lite-1.2.0/assets/img/profile.jpg"
                                             alt="image profile"
                                             class="avatar-img rounded" />
                                    </div>
                                    <div class="u-text">
                                        <h4>Hizrian</h4>
                                        <p class="text-muted">hello@example.com</p>
                                        <a href="profile.html"
                                           class="btn btn-xs btn-secondary btn-sm">View Profile</a>
                                    </div>
                                </div>
                            </li>
                            <li>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="#">My Profile</a>
                                <a class="dropdown-item" href="#">My Balance</a>
                                <a class="dropdown-item" href="#">Inbox</a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="#">Account Setting</a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="#">Logout</a>
                            </li>
            </div>
            </ul>
            </li>
            </ul>
    </div>
    </nav>
</div>