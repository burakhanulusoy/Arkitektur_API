@model LoginUserDto

@{
    Layout = null;
}

<!DOCTYPE html>
<html class="dark" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Arkitektur - Sisteme Giriş</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style type="text/css">
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "tertiary-fixed": "#e8e1dc", "on-tertiary-fixed-variant": "#4a4642", "surface-bright": "#f9f9f9",
                        "on-tertiary-fixed": "#1e1b18", "on-tertiary-container": "#9b9591", "on-secondary-fixed-variant": "#544336",
                        "inverse-primary": "#dec1af", "surface": "#f9f9f9", "error-container": "#ffdad6", "outline": "#81756e",
                        "background": "#f9f9f9", "surface-container-low": "#f3f3f3", "on-primary": "#ffffff", "surface-container-highest": "#e2e2e2",
                        "on-secondary-fixed": "#26190e", "secondary-container": "#f5dbc9", "primary": "#26170c", "surface-container-lowest": "#ffffff",
                        "surface-variant": "#e2e2e2", "surface-container-high": "#e8e8e8", "on-tertiary": "#ffffff", "secondary": "#6e5b4d",
                        "on-secondary-container": "#725f51", "surface-dim": "#dadada", "surface-container": "#eeeeee", "tertiary": "#1c1a17",
                        "secondary-fixed-dim": "#dbc2b0", "secondary-fixed": "#f8decc", "primary-fixed-dim": "#dec1af", "on-primary-fixed-variant": "#574335",
                        "on-primary-container": "#ac9181", "on-background": "#1a1c1c", "on-error": "#ffffff", "error": "#ba1a1a",
                        "on-surface": "#1a1c1c", "on-primary-fixed": "#28180d", "outline-variant": "#d2c4bc", "on-secondary": "#ffffff",
                        "inverse-on-surface": "#f1f1f1", "on-error-container": "#93000a", "inverse-surface": "#2f3131", "primary-fixed": "#fbddca",
                        "surface-tint": "#705a4c", "on-surface-variant": "#4f453f", "tertiary-fixed-dim": "#ccc5c0", "tertiary-container": "#312e2b",
                        "primary-container": "#3d2b1f"
                    },
                    "borderRadius": { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                    "spacing": { "stack-sm": "16px", "stack-md": "32px", "gutter": "24px", "margin": "64px", "unit": "8px", "container-max": "1440px", "stack-lg": "80px" },
                    "fontFamily": { "body-sm": ["inter"], "display-md": ["manrope"], "display-lg": ["manrope"], "headline-md": ["manrope"], "label-lg": ["inter"], "headline-lg": ["manrope"], "label-md": ["inter"], "body-md": ["inter"], "body-lg": ["inter"] },
                    "fontSize": {
                        "body-sm": ["14px", { "lineHeight": "1.5", "fontWeight": "400" }], "display-md": ["48px", { "lineHeight": "1.2", "letterSpacing": "-0.01em", "fontWeight": "300" }],
                        "display-lg": ["64px", { "lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "300" }], "headline-md": ["24px", { "lineHeight": "1.4", "fontWeight": "500" }],
                        "label-lg": ["12px", { "lineHeight": "1", "letterSpacing": "0.1em", "fontWeight": "600" }], "headline-lg": ["32px", { "lineHeight": "1.3", "letterSpacing": "0.02em", "fontWeight": "500" }],
                        "label-md": ["10px", { "lineHeight": "1", "letterSpacing": "0.1em", "fontWeight": "600" }], "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }], "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }]
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-primary min-h-screen text-on-primary font-body-md overflow-x-hidden">
    <div class="flex min-h-screen">
        <div class="w-full lg:w-[45%] flex flex-col justify-between p-gutter md:p-margin bg-primary relative z-10">
            <header class="flex justify-between items-center w-full">
                <a class="font-headline-md text-headline-md font-bold tracking-tighter text-on-primary" href="#">
                    Arkitektur
                </a>
            </header>

            <main class="w-full max-w-md mx-auto my-auto py-stack-lg">
                <div class="mb-stack-md">
                    <h1 class="font-headline-lg text-headline-lg text-on-primary mb-stack-sm">Kurumsal Erişim Sistemi</h1>
                    <p class="font-body-md text-body-md text-inverse-primary">Aktif projelerinizin durumunu, mimari paftaları ve resmi iletişim kayıtlarını görüntülemek için kurumsal bilgilerinizi giriniz.</p>
                </div>

                <form method="post" class="space-y-stack-md">
                    <div class="text-error text-sm font-medium bg-error-container/10 p-2 rounded hidden:empty">
                        @Html.ValidationSummary()
                    </div>

                    <div class="space-y-stack-sm">
                        <div class="relative">
                            <label class="block font-label-lg text-label-lg text-inverse-primary uppercase mb-unit">E-Posta Adresi</label>
                            <input class="w-full bg-transparent border-0 border-b border-inverse-primary focus:border-on-primary focus:ring-0 px-0 py-unit font-body-md text-body-md text-on-primary placeholder-inverse-primary transition-colors rounded-none" placeholder="kurumsal@sirketiniz.com" required asp-for="Email" type="email" />
                        </div>

                        <div class="relative">
                            <label class="block font-label-lg text-label-lg text-inverse-primary uppercase mb-unit">Parola</label>
                            <input class="w-full bg-transparent border-0 border-b border-inverse-primary focus:border-on-primary focus:ring-0 px-0 py-unit font-body-md text-body-md text-on-primary placeholder-inverse-primary transition-colors rounded-none" placeholder="••••••••" required asp-for="Password" type="password" />
                            <a class="absolute right-0 top-0 font-label-lg text-label-lg text-inverse-primary hover:text-on-primary uppercase transition-colors" href="#">Parolamı Unuttum</a>
                        </div>
                    </div>

                    <div class="space-y-stack-sm">
                        <button class="w-full bg-on-primary text-primary font-label-lg text-label-lg uppercase py-4 px-8 hover:bg-inverse-primary transition-colors rounded-none flex justify-center items-center gap-2">
                            Sisteme Giriş Yap
                            <span aria-hidden="true" class="material-symbols-outlined text-lg" data-icon="arrow_forward">arrow_forward</span>

                        </button>

                        <div class="flex items-center gap-4">
                            <div class="h-px bg-inverse-primary/30 flex-1"></div>
                            <span class="font-label-md text-label-md text-inverse-primary uppercase">Güvenli Giriş Seçenekleri</span>
                            <div class="h-px bg-inverse-primary/30 flex-1"></div>
                        </div>

                        <a href="#" class="w-full bg-transparent border border-inverse-primary/50 text-on-primary font-label-lg text-label-lg uppercase py-4 px-8 hover:bg-inverse-primary/10 transition-colors rounded-none flex justify-center items-center gap-3">
                            <svg class="w-5 h-5" fill="none" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path>
                                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path>
                                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"></path>
                                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path>
                            </svg>
                            Google ile Doğrula
                        </a>
                    </div>

                    <div class="text-center mt-stack-sm">
                        <p class="font-body-sm text-body-sm text-inverse-primary">
                            Yeni bir proje talebiniz mi var? <a class="text-on-primary hover:text-inverse-primary transition-colors font-medium border-b border-on-primary pb-px" href="/Auth/Register">Ön görüşme talebi oluşturun</a>.
                        </p>
                    </div>
                </form>
            </main>

            <footer class="w-full pt-stack-md border-t border-inverse-primary/30">
                <div class="flex flex-col md:flex-row justify-between items-center gap-unit">
                    <p class="font-label-md text-label-md text-inverse-primary uppercase tracking-wider">
                        © 2024 Arkitektur. Yapısal Bütünlük & Bilinçli Tasarım.
                    </p>
                    <div class="flex gap-gutter">
                        <a class="font-label-md text-label-md text-inverse-primary hover:text-on-primary uppercase transition-colors" href="#">Gizlilik Politikası</a>
                        <a class="font-label-md text-label-md text-inverse-primary hover:text-on-primary uppercase transition-colors" href="#">Hizmet Şartları</a>
                    </div>
                </div>
            </footer>
        </div>

        <div class="hidden lg:block lg:w-[55%] relative overflow-hidden bg-tertiary">
            <div class="absolute inset-0 bg-gradient-to-l from-transparent to-primary/20 z-10 mix-blend-multiply"></div>
            <img alt="Modern mimari yapı" class="absolute inset-0 w-full h-full object-cover object-center grayscale-[20%] sepia-[10%] contrast-110" data-alt="Modern mimari yapı" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCHr4Fawre6gz6cCQHRluJN3vQ833f2wqZTdbJKYy_Jegn8mrc38nYFcYvNRRt_pO7x6PlQ6hZ0snT9GzDAgR1aYKZBQDkKdO151Pim2Wwi8ix4lA_kDEodimjoz_XADUSy4P105JpJYld6HfNqWqeejmWQZZoOLVUZOqqXqSm16_4Ev8yS0p3sEQtWsPTlV7cWWFjn_IH8ODehljAKGH_kiFpPWwcYpVk4Tuzh_wtFo56NtMVFDNQBDAQDWpu-RKIhuI5p_ol9sW4" />

            <div class="absolute bottom-margin right-margin z-20 bg-primary/80 backdrop-blur-sm p-gutter border border-inverse-primary/20 max-w-sm">
                <p class="font-label-lg text-label-lg text-inverse-primary uppercase mb-unit">Öne Çıkan Mimari Eser</p>
                <h3 class="font-headline-md text-headline-md text-on-primary mb-2">Ekolojik Ahşap Kompleksi</h3>
                <p class="font-body-sm text-body-sm text-inverse-primary line-clamp-2">Sürdürülebilir mimari ve brütalist formların doğayla kurduğu kusursuz dengeyi inceliyoruz.</p>
            </div>
        </div>
    </div>


    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.20.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>



</body>
</html>