@model List<ResultTestimonialDto>

@{
    ViewData["Title"] = "Yorumlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<div class="table-responsive">
    <table class="table table-hover table-bordered">
        <thead>
            <tr>
                <th>#</th>
                <th>Görsel</th>
                <th>Adı ve Soyadı</th>
                <th>Yorumu</th>
                <th>Unvan</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                count++;
                <tr>
                    <td>@count</td>
                    <td>
                        <img src="@item.ImageUrl" alt="@item.NameSurname" style="height:100px; width:100px; object-fit:cover; border-radius:5px;" />
                    </td>
                    <td>@item.NameSurname</td>
                    <td>@item.Comment</td>
                    <td>@item.Title</td>
                    <td>
                        <a href="/Admin/Testimonial/UpdateTestimonail/@item.Id" class="btn btn-primary">
                            <i class="bi bi-pencil-square me-1"></i> Düzenle
                        </a>
                        <button onclick="deleteTestimonial(@item.Id)" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i> Sil
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<a class="btn btn-success mt-3" href="/Admin/Testimonial/CreateTestimonial">
    <i class="bi bi-plus-circle me-1"></i> Yeni Referans Ekle
</a>

<script>
    function deleteTestimonial(id) {
        Swal.fire({
            title: "Silmek istediğinize emin misiniz?",
            text: "Bu işlemi geri alamazsınız!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Evet, sil!",
            cancelButtonText: "İptal"
        }).then((result) => {
            if (result.isConfirmed) {

                // Başarı mesajını ayarla ve bitmesini bekle
                Swal.fire({
                    title: "Silindi!",
                    text: "Kayıt başarılı bir şekilde silindi.",
                    icon: "success",
                    showConfirmButton: false, // Onay butonunu gizle
                    timer: 2000, // Ekranda 2 saniye (2000ms) kalsın
                    timerProgressBar: true // Şık bir geri sayım barı ekle
                }).then(() => {
                    // Alert süresi dolup kapandıktan SONRA yönlendirmeyi yap
                    window.location.href = "/Admin/Testimonial/DeleteTestimonial/" + id;
                });

            }
        });
    }
</script>