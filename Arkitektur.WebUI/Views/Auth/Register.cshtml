@using Arkitektur.WebUI.DTOs.UserDtos
@model CreateUserDto

@{
    Layout = null;
}

<!DOCTYPE html>

<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>ARKITEKTUR - Sisteme Kayıt</title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@300;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-background": "#1a1c1c",
                        "primary-fixed-dim": "#dec1af",
                        "secondary-fixed": "#f8decc",
                        "outline": "#81756e",
                        "surface-container": "#eeeeee",
                        "inverse-surface": "#2f3131",
                        "on-tertiary-fixed-variant": "#4a4642",
                        "surface": "#f9f9f9",
                        "secondary": "#6e5b4d",
                        "error": "#ba1a1a",
                        "on-tertiary-container": "#9b9591",
                        "on-surface-variant": "#4f453f",
                        "surface-container-highest": "#e2e2e2",
                        "tertiary-fixed-dim": "#ccc5c0",
                        "tertiary": "#1c1a17",
                        "on-error": "#ffffff",
                        "outline-variant": "#d2c4bc",
                        "tertiary-fixed": "#e8e1dc",
                        "surface-tint": "#705a4c",
                        "surface-bright": "#f9f9f9",
                        "on-primary-fixed": "#28180d",
                        "on-tertiary-fixed": "#1e1b18",
                        "on-secondary-container": "#725f51",
                        "on-surface": "#1a1c1c",
                        "inverse-primary": "#dec1af",
                        "surface-variant": "#e2e2e2",
                        "secondary-container": "#f5dbc9",
                        "tertiary-container": "#312e2b",
                        "surface-container-high": "#e8e8e8",
                        "primary-container": "#3d2b1f",
                        "on-error-container": "#93000a",
                        "secondary-fixed-dim": "#dbc2b0",
                        "primary-fixed": "#fbddca",
                        "surface-dim": "#dadada",
                        "on-primary": "#ffffff",
                        "on-primary-container": "#ac9181",
                        "background": "#f9f9f9",
                        "surface-container-low": "#f3f3f3",
                        "on-tertiary": "#ffffff",
                        "on-secondary-fixed": "#26190e",
                        "on-secondary": "#ffffff",
                        "surface-container-lowest": "#ffffff",
                        "on-secondary-fixed-variant": "#544336",
                        "inverse-on-surface": "#f1f1f1",
                        "error-container": "#ffdad6",
                        "primary": "#26170c",
                        "on-primary-fixed-variant": "#574335"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "unit": "8px",
                        "stack-md": "32px",
                        "stack-lg": "80px",
                        "stack-sm": "16px",
                        "margin": "64px",
                        "gutter": "24px",
                        "container-max": "1440px"
                    },
                    "fontFamily": {
                        "body-md": ["inter"],
                        "headline-lg": ["manrope"],
                        "display-lg": ["manrope"],
                        "label-md": ["inter"],
                        "body-sm": ["inter"],
                        "body-lg": ["inter"],
                        "headline-md": ["manrope"],
                        "label-lg": ["inter"],
                        "display-md": ["manrope"]
                    },
                    "fontSize": {
                        "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "headline-lg": ["32px", { "lineHeight": "1.3", "letterSpacing": "0.02em", "fontWeight": "500" }],
                        "display-lg": ["64px", { "lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "300" }],
                        "label-md": ["10px", { "lineHeight": "1", "letterSpacing": "0.1em", "fontWeight": "600" }],
                        "body-sm": ["14px", { "lineHeight": "1.5", "fontWeight": "400" }],
                        "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "headline-md": ["24px", { "lineHeight": "1.4", "fontWeight": "500" }],
                        "label-lg": ["12px", { "lineHeight": "1", "letterSpacing": "0.1em", "fontWeight": "600" }],
                        "display-md": ["48px", { "lineHeight": "1.2", "letterSpacing": "-0.01em", "fontWeight": "300" }]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        /* Custom scrollbar for webkit */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #26170c; /* primary */
        }

        ::-webkit-scrollbar-thumb {
            background: #705a4c; /* surface-tint */
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #81756e; /* outline */
            }
    </style>
</head>
<body class="bg-primary text-on-primary min-h-screen selection:bg-inverse-primary selection:text-primary">
    <div class="flex h-screen w-full overflow-hidden">
        <div class="hidden lg:block lg:w-1/2 h-full relative bg-tertiary">
            <img alt="" class="absolute inset-0 w-full h-full object-cover opacity-90" data-alt="high-contrast architectural photography looking up at modern glass and steel skyscraper facade reaching into dark sky, strict geometric grid, dramatic stark lighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBXi7yvBf-xLrE_2crdjxFjVsWp6R6HRMc8nVJza0g8fWL9ie7zyoGR9l7T2fLjPAfVUsY9zmTgApTqTCEGmmpx5Cufmj8f6t0FeQt_j1Z_WmfYyDDvbc05nSGIko1VIJfopCQ4cac9QE7cH2XZaCh44lEGpi6a2C0F6MsJHUahsgjKhSOVMpbtFVuhMf-xyxec8pXlWRwx3AL4FdYOJsQXOU3CCfcTsgq2m8zJcyeyyl65kkWRY8WQS7NSJ0zCc_WI38vH793wCKI" />
            <div class="absolute inset-0 bg-gradient-to-r from-tertiary/20 to-tertiary/60"></div>
            <div class="absolute bottom-margin left-margin">
                <p class="font-label-lg text-label-lg text-tertiary-fixed-dim uppercase tracking-widest mb-unit border-b border-tertiary-fixed-dim/30 pb-unit inline-block">Proje 049</p>
                 <p class="font-body-sm text-body-sm text-surface-container-highest max-w-sm mt-unit">Modern mimarinin temelini oluşturan yapısal bütünlük. Cam ve yapısal çelikte kusursuz geometrik hassasiyet.</p>
            </div>
        </div>
        <div class="w-full lg:w-1/2 h-full overflow-y-auto flex flex-col px-8 md:px-margin lg:px-[120px] py-stack-lg bg-primary relative">
            <div class="my-auto w-full max-w-xl mx-auto">
                <div class="mb-stack-lg">
                    <h1 class="font-headline-md text-headline-md uppercase tracking-[0.2em] text-on-primary">ARKITEKTUR</h1>
                </div>
                <div class="mb-stack-md">
                    <h2 class="font-display-md text-display-md text-on-primary mb-unit">Ayrıcalıklı Ağımıza Katılın</h2>
                    <p class="font-body-lg text-body-lg text-outline-variant">Özel portföyleri, teknik özellikleri ve mimari belgeleri görüntülemek için kayıt olun.</p>
                </div>
                <form class="space-y-stack-sm flex flex-col" method="post">

                    <div class="text-error text-sm font-medium bg-error-container/10 p-2 rounded hidden:empty mb-4">
                        @Html.ValidationSummary()
                    </div>

                    <div class="flex flex-col md:flex-row gap-stack-sm md:gap-gutter">
                        <div class="relative group flex-1">
                            <label class="font-label-lg text-label-lg text-outline-variant uppercase tracking-widest block mb-unit group-focus-within:text-inverse-primary transition-colors" for="firstName">Ad</label>
                            <input class="form-input block w-full border-0 border-b border-outline bg-transparent px-0 py-2 text-on-primary font-body-md text-body-md focus:border-inverse-primary focus:ring-0 transition-colors placeholder:text-outline/40 rounded-none" placeholder="Adınızı girin" required asp-for="FirstName" type="text" />
                            <span asp-validation-for="FirstName" class="text-error text-sm font-medium mt-1 block"></span>
                        </div>
                        <div class="relative group flex-1">
                            <label class="font-label-lg text-label-lg text-outline-variant uppercase tracking-widest block mb-unit group-focus-within:text-inverse-primary transition-colors" for="lastName">Soyad</label>
                            <input class="form-input block w-full border-0 border-b border-outline bg-transparent px-0 py-2 text-on-primary font-body-md text-body-md focus:border-inverse-primary focus:ring-0 transition-colors placeholder:text-outline/40 rounded-none" asp-for="LastName" placeholder="Soyadınızı girin" required type="text" />
                            <span asp-validation-for="LastName" class="text-error text-sm font-medium mt-1 block"></span>
                        </div>
                    </div>
                    <div class="relative group">
                        <label class="font-label-lg text-label-lg text-outline-variant uppercase tracking-widest block mb-unit group-focus-within:text-inverse-primary transition-colors" for="Email">Kurumsal E-Posta</label>
                        <input class="form-input block w-full border-0 border-b border-outline bg-transparent px-0 py-2 text-on-primary font-body-md text-body-md focus:border-inverse-primary focus:ring-0 transition-colors placeholder:text-outline/40 rounded-none" asp-for="Email" placeholder="isim@sirketiniz.com" required type="email" />
                        <span asp-validation-for="Email" class="text-error text-sm font-medium mt-1 block"></span>
                    </div>

                    <div class="relative group">
                        <label class="font-label-lg text-label-lg text-outline-variant uppercase tracking-widest block mb-unit group-focus-within:text-inverse-primary transition-colors" for="PhoneNumber">Telefon Numaranız</label>
                        <input class="form-input block w-full border-0 border-b border-outline bg-transparent px-0 py-2 text-on-primary font-body-md text-body-md focus:border-inverse-primary focus:ring-0 transition-colors placeholder:text-outline/40 rounded-none" asp-for="PhoneNumber" placeholder="0 555 123 45 67" required type="tel" />
                        <span asp-validation-for="PhoneNumber" class="text-error text-sm font-medium mt-1 block"></span>
                    </div>

                    <div class="relative group">
                        <label class="font-label-lg text-label-lg text-outline-variant uppercase tracking-widest block mb-unit group-focus-within:text-inverse-primary transition-colors" for="UserName">Kullanıcı Adı</label>
                        <input class="form-input block w-full border-0 border-b border-outline bg-transparent px-0 py-2 text-on-primary font-body-md text-body-md focus:border-inverse-primary focus:ring-0 transition-colors placeholder:text-outline/40 rounded-none" asp-for="UserName" placeholder="kullaniciadi" type="text" required />
                        <span asp-validation-for="UserName" class="text-error text-sm font-medium mt-1 block"></span>
                    </div>
                    <div class="relative group pt-unit">
                        <label class="font-label-lg text-label-lg text-outline-variant uppercase tracking-widest block mb-unit group-focus-within:text-inverse-primary transition-colors" for="Password">Parola Oluştur</label>
                        <input class="form-input block w-full border-0 border-b border-outline bg-transparent px-0 py-2 text-on-primary font-body-md text-body-md focus:border-inverse-primary focus:ring-0 transition-colors placeholder:text-outline/40 rounded-none" asp-for="Password" placeholder="••••••••" required type="password" />
                        <span asp-validation-for="Password" class="text-error text-sm font-medium mt-1 block"></span>
                    </div>
                    <div class="relative group pt-unit">
                        <label class="font-label-lg text-label-lg text-outline-variant uppercase tracking-widest block mb-unit group-focus-within:text-inverse-primary transition-colors" for="ConfirmPassword">Parolayı Doğrula</label>
                        <input class="form-input block w-full border-0 border-b border-outline bg-transparent px-0 py-2 text-on-primary font-body-md text-body-md focus:border-inverse-primary focus:ring-0 transition-colors placeholder:text-outline/40 rounded-none" asp-for="ConfirmPassword" placeholder="••••••••" required type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-error text-sm font-medium mt-1 block"></span>
                    </div>
                    <div class="pt-stack-md mt-stack-sm flex flex-col gap-stack-sm">
                        <button type="submit" class="w-full bg-inverse-primary text-on-primary-fixed font-label-lg text-label-lg uppercase tracking-[0.15em] py-4 rounded-none hover:bg-secondary-fixed transition-colors flex justify-center items-center gap-2">
                            <span>Kayıt Ol</span>
                            <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                        </button>
                        <div class="text-center mt-unit">
                            <p class="font-body-sm text-body-sm text-outline-variant">
                                Zaten bir hesabınız var mı?
                                <a class="text-inverse-primary hover:text-secondary-fixed transition-colors underline decoration-1 underline-offset-4 ml-1" href="/Auth/Login">Buradan Giriş Yapın</a>
                            </p>
                        </div>
                    </div>
                </form>
            </div>
            <div class="mt-auto pt-stack-lg border-t border-outline/20">
                <p class="font-label-md text-label-md text-outline-variant uppercase tracking-widest">
                    © 2024 ARKITEKTUR MİMARLIK STÜDYOSU — Güvenli Portal
                </p>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.20.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>