@model List<ResultCategoriesWithProjectsDto>
@{
    ViewData["Title"] = "GetCategoriesWithProjects";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<style>
    /* Premium Architectural Theme - Luxury Minimalist */
    :root {
        --arch-dark: #2A2421; /* Çok koyu, asil kahvemsi siyah */
        --arch-gold: #C09867; /* Mat, zarif bronz/altın */
        --arch-bg: #FCFAF8; /* Kemik rengi, sıcak ve çok açık bej */
        --arch-text-muted: #88807B;
    }

    .premium-portfolio-bg {
        background-color: var(--arch-bg);
        font-family: 'Helvetica Neue', Arial, sans-serif; /* Temiz, modern font hissiyatı */
    }

    /* Kategori Başlıkları */
    .premium-category-title {
        color: var(--arch-dark);
        font-weight: 300;
        letter-spacing: 4px;
        text-transform: uppercase;
        font-size: 2rem;
        position: relative;
        display: inline-block;
        padding-bottom: 15px;
        margin-bottom: 40px;
    }

        .premium-category-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 40px;
            height: 2px;
            background-color: var(--arch-gold);
            transition: width 0.4s ease;
        }

    .premium-category-wrapper:hover .premium-category-title::after {
        width: 100%;
    }

    /* Proje Kartı - Minimalist */
    .premium-card {
        background: transparent;
        border: none;
        overflow: hidden;
        margin-bottom: 30px;
    }

    .premium-img-wrapper {
        position: relative;
        overflow: hidden;
        height: 380px; /* Daha uzun, portre hissiyatı veren fotoğraflar */
        width: 100%;
    }

        .premium-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 1.5s cubic-bezier(0.19, 1, 0.22, 1);
            filter: brightness(0.95);
        }

    .premium-card:hover .premium-img-wrapper img {
        transform: scale(1.08);
        filter: brightness(1);
    }

    /* Kart İçi İçerik */
    .premium-card-body {
        padding: 25px 0 10px 0;
    }

    .premium-project-category {
        color: var(--arch-gold);
        font-size: 0.75rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: block;
        font-weight: 600;
    }

    .premium-project-title {
        color: var(--arch-dark);
        font-size: 1.4rem;
        font-weight: 500;
        margin-bottom: 12px;
        transition: color 0.3s ease;
    }

    .premium-card:hover .premium-project-title {
        color: var(--arch-gold);
    }

    .premium-project-desc {
        color: var(--arch-text-muted);
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 20px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Lüks Detay Butonu (Sadece Yazı ve Ok) */
    .premium-btn {
        color: var(--arch-dark);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: all 0.3s ease;
    }

        .premium-btn i {
            margin-left: 10px;
            transition: transform 0.3s ease;
            color: var(--arch-gold);
        }

        .premium-btn:hover {
            color: var(--arch-gold);
        }

            .premium-btn:hover i {
                transform: translateX(8px);
            }

    /* Özellik (Item) Etiketleri */
    .premium-tags {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
        border-top: 1px solid rgba(0,0,0,0.05);
        padding-top: 15px;
    }

        .premium-tags span {
            font-size: 0.8rem;
            color: var(--arch-text-muted);
            display: flex;
            align-items: center;
        }

            .premium-tags span i {
                color: var(--arch-gold);
                margin-right: 6px;
                font-size: 0.7rem;
            }
</style>

<div class="container-fluid py-5 premium-portfolio-bg">
    <div class="container py-5">

        <div class="text-center mx-auto mb-5 pb-4 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 700px;">
            <p style="color: var(--arch-gold); letter-spacing: 3px; text-transform: uppercase; font-size: 0.85rem; font-weight: 600; margin-bottom: 15px;">Proje Portfolyomuz</p>
            <h1 class="display-4" style="color: var(--arch-dark); font-weight: 300;">Mimari Vizyonumuzun <br /> <span style="font-weight: 600; color: var(--arch-gold);">Eserleri</span></h1>
        </div>

        @foreach (var category in Model)
        {
            @if (category.Projects != null && category.Projects.Any())
            {
                <div class="premium-category-wrapper mt-5 pt-4">
                    <div class="row">
                        <div class="col-12 text-center text-md-start">
                            <h2 class="premium-category-title">@category.CategoryName</h2>
                        </div>
                    </div>

                    <div class="row g-5 mt-2">
                        @foreach (var project in category.Projects)
                        {
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.2s">
                                <div class="premium-card">
                                    <div class="premium-img-wrapper">
                                        <img src="@project.ImageUrl" alt="@project.Title">
                                    </div>

                                    <div class="premium-card-body">
                                        <span class="premium-project-category">@category.CategoryName</span>
                                        <h4 class="premium-project-title">@project.Title</h4>
                                        <p class="premium-project-desc">@project.Description</p>

                                        <div class="premium-tags">
                                            <span><i class="fa fa-square"></i> @project.Item1</span>
                                            <span><i class="fa fa-square"></i> @project.Item2</span>
                                        </div>

                                        <a href="/Project/Details/@project.Id" class="premium-btn">
                                            Projeyi Keşfet <i class="fa fa-long-arrow-alt-right"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="py-5"></div>
            }
        }

    </div>
</div>