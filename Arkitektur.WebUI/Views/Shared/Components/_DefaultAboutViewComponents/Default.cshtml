@model ResultAboutDto
@*
    hakkımızda view bileşeni
*@

<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.1s">
                <div class="about-img">
                    <img class="img-fluid" src="https://images.unsplash.com/photo-1549310786-a634d453e653?w=500&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTM4fHxhcmNoaXRlY3R1cmV8ZW58MHx8MHx8fDA%3D" alt="Hakkımızda Görsel 1">
                    <img class="img-fluid" src="https://images.unsplash.com/photo-1496871455396-14e56815f1f4?w=500&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTY0fHxhcmNoaXRlY3R1cmV8ZW58MHx8MHx8fDA%3D" alt="Hakkımızda Görsel 2">
                </div>
            </div>
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.5s">
                <h4 class="section-title">Hakkımızda</h4>
                <h1 class="display-5 mb-4">@Model.Title</h1>
                <p class="mb-4">@Model.Description</p>
                <div class="d-flex align-items-center mb-5">
                    <div class="d-flex flex-shrink-0 align-items-center justify-content-center border border-5 border-primary" style="width: 120px; height: 120px;">
                        <h1 class="display-1 mb-n2" data-toggle="counter-up">@ViewBag.time</h1>
                    </div>
                    <div class="ps-4">
                        <h3>Yıllık</h3>
                        <h3>Sektörel</h3>
                        <h3 class="mb-0">Deneyim</h3>
                    </div>
                </div>
                <a class="btn btn-primary py-3 px-5" href="">Daha Fazla Bilgi</a>
            </div>
        </div>
    </div>
</div>