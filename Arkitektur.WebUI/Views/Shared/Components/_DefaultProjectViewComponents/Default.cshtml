@model List<ResultCategoriesWithProjectsDto>

@*
    getCategoreswithProject component
*@
@{
    int count = 0;
    int tabCount = 0;
}

<div class="container-xxl project py-5">
    <div class="container">
        <div class="text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 600px;">
            <h4 class="section-title">Projelerimiz</h4>
            <h1 class="display-5 mb-4">En Yeni Projelerimizi ve Yenilikçi Çalışmalarımızı İnceleyin</h1>
        </div>
        <div class="row g-4 wow fadeInUp" data-wow-delay="0.3s">

            <div class="col-lg-4">
                <div class="nav nav-pills d-flex flex-column justify-content-between w-100 h-100 me-4">
                    @foreach (var item in Model)
                    {
                        count++;
                        <button class="nav-link w-100 d-flex align-items-center text-start p-4 mb-4 @(count == 1 ? "active" : "")" data-bs-toggle="pill" data-bs-target="#tab-pane-@item.Id" type="button">
                            <h3 class="m-0">@count- @item.CategoryName</h3>
                        </button>
                    }
                </div>
            </div>

            <div class="col-lg-8">
                <div class="tab-content w-100 h-100">
                    @foreach (var item in Model)
                    {
                        tabCount++;
                        <div class="tab-pane fade show h-100 @(tabCount == 1 ? "active" : "")" id="tab-pane-@item.Id">

                            <div class="d-flex flex-column justify-content-between h-100">

                                @* Sadece ilk projeyi (.Take(1) ile) listeliyoruz *@
                                @foreach (var project in item.Projects.Take(1))
                                {
                                    <div class="row g-4 mb-4">
                                        <div class="col-md-6" style="min-height: 420px;">
                                            <div class="position-relative h-100">
                                                <img class="position-absolute img-fluid w-100 h-100 rounded" src="@project.ImageUrl"
                                                     style="object-fit: cover;" alt="">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <h1 class="mb-3">@project.Title</h1>
                                            <p class="mb-4">@project.Description</p>
                                            <p><i class="fa fa-check text-primary me-3"></i>@project.Item1</p>
                                            <p><i class="fa fa-check text-primary me-3"></i>@project.Item2</p>
                                            <p><i class="fa fa-check text-primary me-3"></i>@project.Item3</p>
                                            <a href="/Project/Details/@project.Id" class="btn btn-primary py-3 px-5 mt-3">Proje Detayları</a>
                                        </div>
                                    </div>
                                }

                                @* GENEL TÜM PROJELERİ İNCELE BUTONU *@
                                <div class="row mt-auto">
                                    <div class="col-12 text-center">
                                        <a href="/Project/GetCategoriesWithProjects" class="btn btn-outline-primary py-3 px-5 w-100">
                                            Tüm Projeleri İncele <i class="fa fa-arrow-right ms-2"></i>
                                        </a>
                                    </div>
                                </div>

                            </div>

                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</div>